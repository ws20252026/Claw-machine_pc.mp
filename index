<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>反詐騙挑戰賽</title>
    <link rel="stylesheet" href="style.css">
    <style>
        /* 手機控制面板 */
        #mobile-controls {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 12px;
            margin: 20px auto 10px;
            width: 90%;
            max-width: 550px;
        }

        .ctrl-btn {
            flex: 1;
            padding: 15px 0;
            font-size: 18px;
            font-weight: bold;
            color: white;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            box-shadow: 0 4px 0 rgba(0,0,0,0.3);
            background-color: #6c757d;
            touch-action: manipulation; /* 重要：防止手機連點縮放 */
            user-select: none;
        }

        #btn-drop {
            background-color: #e67e22;
            flex: 1.5; /* 讓抓取按鈕大一點 */
        }

        .ctrl-btn:active {
            transform: translateY(4px);
            box-shadow: none;
        }
    </style>
</head>
<body>

<div id="login-overlay" class="login-screen">
    <div class="login-card">
        <h2>🛡️ 廉政挑戰賽</h2>
        <p>請輸入您的姓名或分機開始挑戰</p>
        <input type="text" id="player-name" placeholder="您的名字..." maxlength="10">
        <button class="action-btn" onclick="startGameWithLogin()">進入遊戲</button>
        <p style="font-size: 11px; color: #888; margin-top: 15px;">文山區公所政風室自製</p>
    </div>
</div>

<div id="game-container">
    <div id="header">
        <div class="question-box">
            <div>🛡️ 題目：<br><span id="target-answer">載入中...</span></div>
        </div>
        <div class="header-right">
            <div id="user-display">挑戰者：未登錄</div>
            <div class="score-box">得分：<span id="score">0</span> / 100</div>
            <button id="manual-reset-btn" onclick="confirmReset()">🔄 重新開始</button>
        </div>
    </div>
    
    <div id="status-bar">
        <div class="timer-box">⏱️ 剩餘時間：<span id="timer">60</span>s</div>
        <div id="instruction">🎮 任務：對準中心！(⬅️ ➡️ 移動，空白鍵下抓)</div>
    </div>

    <div id="machine-wrapper">
        <div id="machine-inner">
            <div id="claw-body">
                <div class="line"></div>
                <div class="hand"></div>
            </div>
            <div id="items-area"></div>
            
            <div id="game-over-overlay" class="overlay">
                <h2>⌛ 時間到！</h2>
                <p>最終得分：<span id="final-score">0</span></p>
                <button class="action-btn" onclick="restartGame()">重新挑戰</button>
            </div>

            <div id="win-overlay" class="overlay">
                <h2>🏆 恭喜通關！</h2>
                <p><span id="winner-name-display" style="color:#2ecc71; font-weight:bold;"></span> 已成為廉政小高手！</p>
                <button class="action-btn" onclick="restartGame()" style="background: #f1c40f; color: #333;">再玩一次</button>
            </div>
        </div>
    </div>

    <div id="mobile-controls">
        <button type="button" class="ctrl-btn" id="btn-left">⬅️ 左移</button>
        <button type="button" class="ctrl-btn" id="btn-drop">🏗️ 抓取</button>
        <button type="button" class="ctrl-btn" id="btn-right">右移 ➡️</button>
    </div>

    <div style="text-align: right; font-size: 13px; color: #bdc3c7; margin-top: 10px; font-weight: bold;">
        文山區公所政風室自製
    </div>
</div>

<script src="script.js"></script>

<script>
    // 確保 script.js 載入後再綁定事件
    window.onload = function() {
        document.getElementById('btn-left').onclick = function() {
            if (typeof isDropping !== 'undefined' && !isDropping && !isGameOver && playerName) {
                if (clawX > 40) clawX -= 25;
                document.getElementById('claw-body').style.left = clawX + 'px';
            }
        };
        document.getElementById('btn-right').onclick = function() {
            if (typeof isDropping !== 'undefined' && !isDropping && !isGameOver && playerName) {
                if (clawX < 480) clawX += 25;
                document.getElementById('claw-body').style.left = clawX + 'px';
            }
        };
        document.getElementById('btn-drop').onclick = function() {
            if (typeof dropClaw === 'function') dropClaw();
        };
    };
</script>
</body>
</html>
